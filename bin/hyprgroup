#!/usr/bin/env bash
set -euo pipefail

app_name="HyprGroup"

usage() {
	printf '%s\n' \
		"Usage: hyprgroup [menu|daemon|add|move-here|remove|snapshot]" \
		"" \
		"Actions:" \
		"  menu       Toggle the Quickshell action menu" \
		"  daemon     Start the persistent Quickshell menu process" \
		"  add        Add the active window to a native Container" \
		"  move-here  Move the remembered Container to the active workspace" \
		"  remove     Remove the active window from its Container" \
		"  snapshot   Print the active or remembered Container state as JSON"
}

notify() {
	local message="$1"

	if command -v notify-send >/dev/null 2>&1; then
		notify-send "$app_name" "$message"
	else
		printf '%s: %s\n' "$app_name" "$message" >&2
	fi
}

dispatch_output_failed() {
	local output="$1"

	[[ "$output" == error:* || "$output" == *$'\nerror:'* ]]
}

run_dispatch() {
	local dispatcher="$1"
	local output

	if output="$(hyprctl dispatch "$dispatcher" 2>&1)" && ! dispatch_output_failed "$output"; then
		return 0
	fi

	notify "Hyprland did not accept the container command."
	return 1
}

state_file() {
	printf '%s\n' "${XDG_RUNTIME_DIR:-/tmp}/hyprgroup-containers.tsv"
}

script_path() {
	local script_dir
	local script_name

	script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
	script_name="$(basename -- "${BASH_SOURCE[0]}")"
	printf '%s/%s\n' "$script_dir" "$script_name"
}

command_path() {
	if [[ -n "${HYPRGROUP_COMMAND_PATH:-}" ]]; then
		printf '%s\n' "$HYPRGROUP_COMMAND_PATH"
		return
	fi

	script_path
}

active_workspace_id() {
	hyprctl activeworkspace -j 2>/dev/null |
		jq -r '.id // empty' 2>/dev/null
}

active_window_address() {
	hyprctl activewindow -j 2>/dev/null |
		jq -r '.address // empty' 2>/dev/null
}

client_exists() {
	local address="$1"

	hyprctl clients -j 2>/dev/null |
		jq -e --arg address "$address" 'any(.[]; .address == $address)' >/dev/null 2>&1
}

client_workspace_id() {
	local address="$1"

	hyprctl clients -j 2>/dev/null |
		jq -r --arg address "$address" '.[] | select(.address == $address) | .workspace.id // empty' 2>/dev/null
}

stored_container_anchor_address() {
	local state

	state="$(state_file)"
	[[ -f "$state" ]] || return 1

	awk '
		BEGIN { FS = "\t" }
		$1 == "anchor" && $2 ~ /^0x[0-9a-fA-F]+$/ { print $2; found = 1; exit }
		END { exit found ? 0 : 1 }
	' "$state"
}

container_anchor_address() {
	local address

	if address="$(stored_container_anchor_address)" && client_exists "$address"; then
		printf '%s\n' "$address"
		return 0
	fi

	return 1
}

remember_container_anchor() {
	local address="${1:-}"
	local state
	local tmp

	if [[ -z "$address" ]]; then
		address="$(active_window_address)" || return 1
	fi

	[[ "$address" =~ ^0x[0-9a-fA-F]+$ ]] || return 1

	state="$(state_file)"
	tmp="${state}.$$"

	printf 'anchor\t%s\n' "$address" >"$tmp"
	mv "$tmp" "$state"
}

forget_container_anchor() {
	local state

	state="$(state_file)"
	: >"$state"
}

forget_stale_container_anchor() {
	local address

	address="$(stored_container_anchor_address || true)"

	if [[ "$address" =~ ^0x[0-9a-fA-F]+$ ]] && ! client_exists "$address"; then
		forget_container_anchor || true
	fi
}

active_window_in_container() {
	local grouped_count
	local address
	local container_address

	if ! command -v jq >/dev/null 2>&1; then
		return 2
	fi

	if ! read -r grouped_count address < <(
		hyprctl activewindow -j 2>/dev/null |
			jq -r '[((.grouped // []) | length), .address] | @tsv' 2>/dev/null
	); then
		return 2
	fi

	if [[ ! "$grouped_count" =~ ^[0-9]+$ ]]; then
		return 2
	fi

	if (( grouped_count > 0 )); then
		return 0
	fi

	if container_address="$(container_anchor_address)" && [[ "$address" == "$container_address" ]]; then
		return 0
	fi

	return 1
}

active_window_remove_state() {
	hyprctl activewindow -j 2>/dev/null |
		jq -r '
			.address as $active |
			(.grouped // []) as $grouped |
			[
				($active // ""),
				($grouped | length),
				([$grouped[] | tostring | select(. != $active)] | .[0] // "")
			] | @tsv
		' 2>/dev/null
}

empty_snapshot() {
	printf '%s\n' '{"hasContainer":false,"address":"","title":"No Active Window","className":"","grouped":[],"windows":[],"source":"none"}'
}

container_snapshot() {
	local anchor_address=""

	if ! command -v jq >/dev/null 2>&1; then
		empty_snapshot
		return 0
	fi

	forget_stale_container_anchor
	anchor_address="$(stored_container_anchor_address || true)"

	if ! {
		hyprctl activewindow -j 2>/dev/null
		hyprctl clients -j 2>/dev/null
	} | jq -cs --arg anchor "$anchor_address" '
		def dedupe:
			reduce .[] as $item ([]; if index($item) then . else . + [$item] end);

		def normalize_group($raw; $address; $clients):
			(if ($raw | length) == 0 then
				[$address]
			elif ($raw | index($address)) then
				$raw
			else
				[$address] + $raw
			end) |
			dedupe |
			map(select(. == $address or (. as $candidate | any($clients[]?; .address == $candidate))));

		def window_title($client):
			(($client.title // "") | if . == "" then "Untitled window" else . end);

		def window_details($grouped; $clients; $primary):
			[
				$grouped[] as $address |
				(($clients | map(select(.address == $address)) | .[0]) //
					(if (($primary.address // "") == $address) then $primary else null end)) as $client |
				{
					address: $address,
					title: window_title($client),
					className: ($client.class // "")
				}
			];

		def snapshot($client; $grouped; $source; $clients):
			{
				hasContainer: true,
				address: ($client.address // ""),
				title: window_title($client),
				className: ($client.class // ""),
				grouped: $grouped,
				windows: window_details($grouped; $clients; $client),
				source: $source
			};

		.[0] as $active |
		(.[1] // []) as $clients |
		([($active.grouped // [])[]? | tostring] | normalize_group(.; ($active.address // ""); $clients)) as $active_grouped |
		if (($active.address // "") != "" and ($active_grouped | length) > 1) then
			snapshot($active; $active_grouped; "active"; $clients)
		else
			($clients | map(select(.address == $anchor)) | .[0] // null) as $anchor_client |
			if ($anchor_client != null) then
				([($anchor_client.grouped // [])[]? | tostring] | normalize_group(.; $anchor; $clients)) as $remembered_grouped |
				snapshot($anchor_client; $remembered_grouped; "remembered"; $clients)
			else
				{
					hasContainer: false,
					address: "",
					title: "No Active Window",
					className: "",
					grouped: [],
					windows: [],
					source: "none"
				}
			end
		end
	' 2>/dev/null; then
		empty_snapshot
	fi
}

group_addresses_for_window() {
	local address="$1"

	hyprctl clients -j 2>/dev/null |
		jq -r --arg address "$address" '
			def dedupe:
				reduce .[] as $item ([]; if index($item) then . else . + [$item] end);

			(.[] | select(.address == $address)) as $client |
			([($client.grouped // [])[]? | tostring] |
				if length == 0 then
					[]
				elif index($address) then
					.
				else
					[$address] + .
				end |
				dedupe |
				.[])
		' 2>/dev/null
}

container_window_addresses() {
	local anchor_address="$1"
	local addresses=()
	local address
	local printed=0

	mapfile -t addresses < <(group_addresses_for_window "$anchor_address")

	if (( ${#addresses[@]} == 0 )); then
		addresses=("$anchor_address")
	fi

	for address in "${addresses[@]}"; do
		if [[ "$address" =~ ^0x[0-9a-fA-F]+$ ]] && client_exists "$address"; then
			printf '%s\n' "$address"
			printed=1
		fi
	done

	if (( printed == 0 )) && client_exists "$anchor_address"; then
		printf '%s\n' "$anchor_address"
	fi
}

container_direction_on_active_workspace() {
	local direction
	local container_address=""

	if ! command -v jq >/dev/null 2>&1; then
		return 1
	fi

	container_address="$(container_anchor_address || true)"

	if ! direction="$(
		{
			hyprctl activewindow -j 2>/dev/null
			hyprctl clients -j 2>/dev/null
		} | jq -rs --arg container_address "$container_address" '
			.[0] as $active |
			.[1] as $clients |
			($active.at[0] + ($active.size[0] / 2)) as $active_x |
			($active.at[1] + ($active.size[1] / 2)) as $active_y |
			[
				$clients[]
				| select(.address != $active.address)
				| select(.monitor == $active.monitor)
				| select(.workspace.id == $active.workspace.id)
				| select((((.grouped // []) | length) > 0) or (.address == $container_address))
				| . + {
					target_rank: (if .address == $container_address then 0 else 1 end),
					group_count: ((.grouped // []) | length),
					center_x: (.at[0] + (.size[0] / 2)),
					center_y: (.at[1] + (.size[1] / 2))
				}
				| . + {
					dx: (.center_x - $active_x),
					dy: (.center_y - $active_y)
				}
				| . + {
					abs_dx: (if .dx < 0 then -.dx else .dx end),
					abs_dy: (if .dy < 0 then -.dy else .dy end)
				}
				| . + {
					direction: (
						if .abs_dx >= .abs_dy then
							if .dx < 0 then "l" else "r" end
						else
							if .dy < 0 then "u" else "d" end
						end
					),
					distance: ((.dx * .dx) + (.dy * .dy))
				}
			]
			| sort_by(.target_rank, -.group_count, (.focusHistoryID // 999999), .distance)
			| .[0].direction // empty
		' 2>/dev/null
	)"; then
		return 1
	fi

	if [[ "$direction" =~ ^[lrud]$ ]]; then
		printf '%s\n' "$direction"
		return 0
	fi

	return 1
}

ensure_active_window_normal() {
	run_dispatch 'hl.dsp.window.fullscreen({ action = "unset" })'
	run_dispatch 'hl.dsp.window.float({ action = "off" })'
}

move_into_container() {
	local direction="$1"

	run_dispatch "hl.dsp.window.move({ into_or_create_group = \"${direction}\" })"
}

move_window_to_workspace() {
	local workspace="$1"
	local address="$2"

	run_dispatch "hl.dsp.window.move({ workspace = ${workspace}, window = \"address:${address}\" })"
}

bring_container_to_active_workspace() {
	local container_address
	local target_workspace
	local container_addresses=()
	local address
	local address_workspace

	container_address="$(container_anchor_address)" || return 1
	target_workspace="$(active_workspace_id)" || return 1

	[[ "$container_address" =~ ^0x[0-9a-fA-F]+$ ]] || return 1
	[[ "$target_workspace" =~ ^-?[0-9]+$ ]] || return 1

	mapfile -t container_addresses < <(container_window_addresses "$container_address")

	if (( ${#container_addresses[@]} == 0 )); then
		return 1
	fi

	for address in "${container_addresses[@]}"; do
		address_workspace="$(client_workspace_id "$address" || true)"

		if [[ "$address_workspace" == "$target_workspace" ]]; then
			continue
		fi

		move_window_to_workspace "$target_workspace" "$address" || return 1
	done
}

lock_active_container() {
	run_dispatch 'hl.dsp.group.lock_active({ action = "lock" })'
}

create_container_from_active_window() {
	run_dispatch 'hl.dsp.group.toggle({})'
	lock_active_container
}

add_to_group() {
	local direction
	local state=0

	if command -v jq >/dev/null 2>&1; then
		forget_stale_container_anchor
	fi

	if active_window_in_container; then
		return 0
	else
		state=$?
	fi

	if [[ "$state" -eq 1 ]]; then
		ensure_active_window_normal || return 1
		bring_container_to_active_workspace || true

		if direction="$(container_direction_on_active_workspace)"; then
			move_into_container "$direction" || return 1

			if active_window_in_container; then
				remember_container_anchor || true
				lock_active_container
				return 0
			fi
		fi

		create_container_from_active_window
		remember_container_anchor || true
		return
	fi

	notify "Could not inspect the active window."
	return 1
}

move_container_here() {
	local container_address
	local target_workspace

	if ! command -v jq >/dev/null 2>&1; then
		notify "Could not inspect the Container."
		return 1
	fi

	target_workspace="$(active_workspace_id || true)"
	forget_stale_container_anchor
	container_address="$(container_anchor_address || true)"

	if [[ ! "$target_workspace" =~ ^-?[0-9]+$ ]]; then
		notify "Could not inspect the active workspace."
		return 1
	fi

	if [[ ! "$container_address" =~ ^0x[0-9a-fA-F]+$ ]]; then
		notify "No Container to move."
		return 1
	fi

	bring_container_to_active_workspace || {
		notify "Could not move the Container."
		return 1
	}
}

remove_window() {
	local active_address
	local grouped_count
	local remaining_address
	local container_address

	if ! command -v jq >/dev/null 2>&1; then
		notify "Could not inspect the active window."
		return 1
	fi

	forget_stale_container_anchor

	if ! read -r active_address grouped_count remaining_address < <(active_window_remove_state); then
		notify "Could not inspect the active window."
		return 1
	fi

	if [[ -z "$active_address" || ! "$grouped_count" =~ ^[0-9]+$ ]]; then
		notify "Could not inspect the active window."
		return 1
	fi

	if (( grouped_count > 0 )); then
		run_dispatch 'hl.dsp.window.move({ out_of_group = true })' || return 1

		if [[ "$remaining_address" =~ ^0x[0-9a-fA-F]+$ ]]; then
			remember_container_anchor "$remaining_address" || true
		else
			forget_container_anchor || true
		fi

		return 0
	fi

	container_address="$(container_anchor_address || true)"

	if [[ -n "$container_address" && "$active_address" == "$container_address" ]]; then
		forget_container_anchor || true
	fi

	return 0
}

qs_dir() {
	local script_dir

	script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
	printf '%s\n' "${script_dir}/../qs"
}

js_string() {
	local value="$1"

	value="${value//\\/\\\\}"
	value="${value//\"/\\\"}"
	printf '%s' "$value"
}

write_qs_runtime_config() {
	local runtime_file
	local tmp
	local command_path

	runtime_file="$(qs_dir)/HyprGroupRuntime.js"
	tmp="${runtime_file}.$$"
	command_path="$(js_string "$(command_path)")"

	{
		printf '%s\n' ".pragma library"
		printf 'var commandPath = "%s";\n' "$command_path"
	} >"$tmp"
	mv "$tmp" "$runtime_file"
}

qs_running() {
	quickshell list --path "$(qs_dir)" --any-display 2>/dev/null | grep -q '^Instance '
}

cursor_position() {
	local pos
	local x
	local y

	if ! pos="$(hyprctl cursorpos 2>/dev/null)"; then
		return 1
	fi

	pos="${pos// /}"
	x="${pos%%,*}"
	y="${pos#*,}"

	if [[ "$x" =~ ^-?[0-9]+$ && "$y" =~ ^-?[0-9]+$ ]]; then
		printf '%s %s\n' "$x" "$y"
		return 0
	fi

	return 1
}

daemon() {
	if ! command -v quickshell >/dev/null 2>&1; then
		return 1
	fi

	write_qs_runtime_config || return 1

	if qs_running; then
		return 0
	fi

	quickshell --path "$(qs_dir)" --daemonize >/dev/null 2>&1
}

menu() {
	local dir
	local coords
	local x
	local y

	dir="$(qs_dir)"

	if ! command -v quickshell >/dev/null 2>&1; then
		notify "quickshell is required for the menu."
		return 1
	fi

	daemon || return 1

	if coords="$(cursor_position)"; then
		x="${coords% *}"
		y="${coords#* }"
		quickshell ipc --path "$dir" --any-display call hyprgroup toggleAt "$x" "$y"
	else
		quickshell ipc --path "$dir" --any-display call hyprgroup toggle
	fi
}

main() {
	local action="${1:-menu}"

	case "$action" in
		menu) menu ;;
		daemon) daemon ;;
		add) add_to_group ;;
		move-here) move_container_here ;;
		remove) remove_window ;;
		snapshot) container_snapshot ;;
		-h|--help|help) usage ;;
		*) usage >&2; return 2 ;;
	esac
}

main "$@"
