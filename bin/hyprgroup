#!/usr/bin/env bash
set -euo pipefail

app_name="HyprGroup"

usage() {
	printf '%s\n' \
		"Usage: hyprgroup [menu|daemon|add|move-here|remove|close|select|reorder|snapshot|jump|next|prev]" \
		"" \
		"Actions:" \
		"  menu       Toggle the Quickshell action menu" \
		"  daemon     Start the persistent Quickshell menu process" \
		"  add        Add the active window to the Container if needed" \
		"  move-here  Move the remembered Container to the active workspace" \
		"  remove     Remove the active window from its group" \
		"  close      Close the active or selected Container window" \
		"  select     Select a Container window without staying focused there" \
		"  reorder    Move a group window to a zero-based Container index" \
		"  snapshot   Print the active or remembered Container state as JSON" \
		"  jump       Focus a group window by address" \
		"  next       Focus the next window in the active group" \
		"  prev       Focus the previous window in the active group"
}

notify() {
	local message="$1"

	if command -v notify-send >/dev/null 2>&1; then
		notify-send "$app_name" "$message"
	else
		printf '%s: %s\n' "$app_name" "$message" >&2
	fi
}

dispatch_output_failed() {
	local output="$1"

	[[ "$output" == error:* || "$output" == *$'\nerror:'* ]]
}

run_dispatch() {
	local dispatcher="$1"
	local output

	if output="$(hyprctl dispatch "$dispatcher" 2>&1)" && ! dispatch_output_failed "$output"; then
		return 0
	fi

	notify "Hyprland did not accept the container command."
	return 1
}

active_window_in_container() {
	local address
	local container_address
	local grouped_has_anchor

	if ! command -v jq >/dev/null 2>&1; then
		return 2
	fi

	container_address="$(container_anchor_address || true)"

	if [[ ! "$container_address" =~ ^0x[0-9a-fA-F]+$ ]]; then
		return 1
	fi

	if ! read -r address grouped_has_anchor < <(
		hyprctl activewindow -j 2>/dev/null |
			jq -r --arg anchor "$container_address" '[.address // "", ((.grouped // []) | index($anchor) != null)] | @tsv' 2>/dev/null
	); then
		return 2
	fi

	if [[ ! "$address" =~ ^0x[0-9a-fA-F]+$ ]]; then
		return 1
	fi

	if [[ "$address" == "$container_address" || "$grouped_has_anchor" == "true" ]]; then
		return 0
	fi

	group_contains_address "$container_address" "$address"
}

active_window_in_native_group() {
	local grouped_count
	local address

	if ! command -v jq >/dev/null 2>&1; then
		return 2
	fi

	if ! read -r grouped_count address < <(
		hyprctl activewindow -j 2>/dev/null |
			jq -r '[((.grouped // []) | length), .address] | @tsv' 2>/dev/null
	); then
		return 2
	fi

	if [[ ! "$grouped_count" =~ ^[0-9]+$ ]]; then
		return 2
	fi

	if [[ "$address" =~ ^0x[0-9a-fA-F]+$ ]] && (( grouped_count > 0 )); then
		return 0
	fi

	return 1
}

state_file() {
	printf '%s\n' "${XDG_RUNTIME_DIR:-/tmp}/hyprgroup-containers.tsv"
}

script_path() {
	local script_dir
	local script_name

	script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
	script_name="$(basename -- "${BASH_SOURCE[0]}")"
	printf '%s/%s\n' "$script_dir" "$script_name"
}

command_path() {
	if [[ -n "${HYPRGROUP_COMMAND_PATH:-}" ]]; then
		printf '%s\n' "$HYPRGROUP_COMMAND_PATH"
		return
	fi

	script_path
}

active_workspace_id() {
	hyprctl activeworkspace -j 2>/dev/null |
		jq -r '.id // empty' 2>/dev/null
}

active_window_address() {
	hyprctl activewindow -j 2>/dev/null |
		jq -r '.address // empty' 2>/dev/null
}

client_exists() {
	local address="$1"

	hyprctl clients -j 2>/dev/null |
		jq -e --arg address "$address" 'any(.[]; .address == $address)' >/dev/null 2>&1
}

client_workspace_id() {
	local address="$1"

	hyprctl clients -j 2>/dev/null |
		jq -r --arg address "$address" '.[] | select(.address == $address) | .workspace.id // empty' 2>/dev/null
}

stored_container_anchor_address() {
	local state

	state="$(state_file)"
	[[ -f "$state" ]] || return 1

	awk '
		BEGIN { FS = "\t" }
		$1 == "anchor" && $2 ~ /^0x[0-9a-fA-F]+$/ { print $2; found = 1; exit }
		NF >= 3 && $3 ~ /^0x[0-9a-fA-F]+$/ { fallback = $3 }
		END {
			if (found) {
				exit 0
			}
			if (fallback != "") {
				print fallback
				exit 0
			}
			exit 1
		}
	' "$state"
}

container_anchor_address() {
	local address

	if address="$(stored_container_anchor_address)" && client_exists "$address"; then
		printf '%s\n' "$address"
		return 0
	fi

	return 1
}

remember_container_anchor() {
	local address="${1:-}"
	local state
	local tmp

	if [[ -z "$address" ]]; then
		address="$(active_window_address)" || return 1
	fi

	[[ "$address" =~ ^0x[0-9a-fA-F]+$ ]] || return 1

	state="$(state_file)"
	tmp="${state}.$$"

	printf 'anchor\t%s\n' "$address" >"$tmp"
	mv "$tmp" "$state"
}

forget_container_anchor() {
	local state

	state="$(state_file)"
	: >"$state"
}

forget_stale_container_anchor() {
	local address

	address="$(stored_container_anchor_address || true)"

	if [[ "$address" =~ ^0x[0-9a-fA-F]+$ ]] && ! client_exists "$address"; then
		forget_container_anchor || true
	fi
}

active_window_remove_state() {
	hyprctl activewindow -j 2>/dev/null |
		jq -r '
			.address as $active |
			(.grouped // []) as $grouped |
			[
				($active // ""),
				($grouped | length),
				([$grouped[] | tostring | select(. != $active)] | .[0] // "")
			] | @tsv
		' 2>/dev/null
}

window_close_state() {
	local address="$1"

	hyprctl clients -j 2>/dev/null |
		jq -r --arg address "$address" '
			(.[] | select(.address == $address)) as $target |
			($target.grouped // []) as $grouped |
			[
				($target.address // ""),
				($grouped | length),
				([$grouped[] | tostring | select(. != $address)] | .[0] // "")
			] | @tsv
		' 2>/dev/null
}

empty_snapshot() {
	printf '%s\n' '{"hasContainer":false,"address":"","title":"No Active Window","className":"","grouped":[],"windows":[],"source":"none"}'
}

container_snapshot() {
	local anchor_address=""

	if ! command -v jq >/dev/null 2>&1; then
		empty_snapshot
		return 0
	fi

	forget_stale_container_anchor
	anchor_address="$(stored_container_anchor_address || true)"

	if ! {
		hyprctl activewindow -j 2>/dev/null
		hyprctl clients -j 2>/dev/null
	} | jq -cs --arg anchor "$anchor_address" '
		def dedupe:
			reduce .[] as $item ([]; if index($item) then . else . + [$item] end);

		def normalize_group($raw; $address; $clients):
			(if ($raw | length) == 0 then
				[$address]
			elif ($raw | index($address)) then
				$raw
			else
				[$address] + $raw
			end) |
			dedupe |
			map(select(. == $address or (. as $candidate | any($clients[]?; .address == $candidate))));

		def window_title($client):
			(($client.title // "") | if . == "" then "Untitled window" else . end);

		def window_details($grouped; $clients; $primary):
			[
				$grouped[] as $address |
				(($clients | map(select(.address == $address)) | .[0]) //
					(if (($primary.address // "") == $address) then $primary else null end)) as $client |
				{
					address: $address,
					title: window_title($client),
					className: ($client.class // "")
				}
			];

		def remembered_active_client($grouped; $clients; $anchor):
			([
				$clients[]?
				| select(.address as $candidate | ($grouped | index($candidate)))
				| . + {
					__history_rank: (.focusHistoryID // 999999),
					__anchor_rank: (if .address == $anchor then 0 else 1 end)
				}
			]
			| sort_by(.__history_rank, .__anchor_rank)
			| .[0]) // null;

		def snapshot($client; $grouped; $source; $clients):
			{
				hasContainer: true,
				address: ($client.address // ""),
				title: window_title($client),
				className: ($client.class // ""),
				grouped: $grouped,
				windows: window_details($grouped; $clients; $client),
				source: $source
			};

		.[0] as $active |
		(.[1] // []) as $clients |
		($clients | map(select(.address == $anchor)) | .[0] // null) as $anchor_client |
		if ($anchor_client != null) then
			([($anchor_client.grouped // [])[]? | tostring] | normalize_group(.; $anchor; $clients)) as $managed_grouped |
			if ($managed_grouped | length) > 0 then
				($active.address // "") as $active_address |
				if ($active_address != "" and ($managed_grouped | index($active_address))) then
					snapshot($active; $managed_grouped; "active"; $clients)
				else
					(remembered_active_client($managed_grouped; $clients; $anchor) // $anchor_client) as $remembered_client |
					snapshot($remembered_client; $managed_grouped; "remembered"; $clients)
				end
			else
				{
					hasContainer: false,
					address: "",
					title: "No Active Window",
					className: "",
					grouped: [],
					windows: [],
					source: "none"
				}
			end
		else
			{
				hasContainer: false,
				address: "",
				title: "No Active Window",
				className: "",
				grouped: [],
				windows: [],
				source: "none"
			}
		end
	' 2>/dev/null; then
		empty_snapshot
	fi
}

group_addresses_for_window() {
	local address="$1"

	hyprctl clients -j 2>/dev/null |
		jq -r --arg address "$address" '
			def dedupe:
				reduce .[] as $item ([]; if index($item) then . else . + [$item] end);

			(.[] | select(.address == $address)) as $client |
			([($client.grouped // [])[]? | tostring] |
				if length == 0 then
					[]
				elif index($address) then
					.
				else
					[$address] + .
				end |
				dedupe |
				.[])
		' 2>/dev/null
}

container_window_addresses() {
	local anchor_address="$1"
	local addresses=()
	local address
	local printed=0

	mapfile -t addresses < <(group_addresses_for_window "$anchor_address")

	if (( ${#addresses[@]} == 0 )); then
		addresses=("$anchor_address")
	fi

	for address in "${addresses[@]}"; do
		if [[ "$address" =~ ^0x[0-9a-fA-F]+$ ]] && client_exists "$address"; then
			printf '%s\n' "$address"
			printed=1
		fi
	done

	if (( printed == 0 )) && client_exists "$anchor_address"; then
		printf '%s\n' "$anchor_address"
	fi
}

remembered_container_active_address() {
	local anchor_address

	anchor_address="$(container_anchor_address)" || return 1

	hyprctl clients -j 2>/dev/null |
		jq -r --arg anchor "$anchor_address" '
			def dedupe:
				reduce .[] as $item ([]; if index($item) then . else . + [$item] end);

			. as $clients |
			($clients[] | select(.address == $anchor)) as $anchor_client |
			([($anchor_client.grouped // [])[]? | tostring] |
				if length == 0 then
					[$anchor]
				elif index($anchor) then
					.
				else
					[$anchor] + .
				end |
				dedupe) as $grouped |
			[
				$clients[]
				| select(.address as $candidate | ($grouped | index($candidate)))
				| {
					address: .address,
					history: (.focusHistoryID // 999999),
					anchor_rank: (if .address == $anchor then 0 else 1 end)
				}
			]
			| sort_by(.history, .anchor_rank)
			| .[0].address // empty
		' 2>/dev/null
}

container_direction_on_active_workspace() {
	local direction
	local container_address=""

	if ! command -v jq >/dev/null 2>&1; then
		return 1
	fi

	container_address="$(container_anchor_address || true)"

	if ! direction="$(
		{
			hyprctl activewindow -j 2>/dev/null
			hyprctl clients -j 2>/dev/null
		} | jq -rs --arg container_address "$container_address" '
			.[0] as $active |
			.[1] as $clients |
			($active.at[0] + ($active.size[0] / 2)) as $active_x |
			($active.at[1] + ($active.size[1] / 2)) as $active_y |
			[
				$clients[]
				| select(.address != $active.address)
				| select(.monitor == $active.monitor)
				| select(.workspace.id == $active.workspace.id)
				| select((((.grouped // []) | length) > 0) or (.address == $container_address))
				| . + {
					target_rank: (if .address == $container_address then 0 else 1 end),
					group_count: ((.grouped // []) | length),
					center_x: (.at[0] + (.size[0] / 2)),
					center_y: (.at[1] + (.size[1] / 2))
				}
				| . + {
					dx: (.center_x - $active_x),
					dy: (.center_y - $active_y)
				}
				| . + {
					abs_dx: (if .dx < 0 then -.dx else .dx end),
					abs_dy: (if .dy < 0 then -.dy else .dy end)
				}
				| . + {
					direction: (
						if .abs_dx >= .abs_dy then
							if .dx < 0 then "l" else "r" end
						else
							if .dy < 0 then "u" else "d" end
						end
					),
					distance: ((.dx * .dx) + (.dy * .dy))
				}
			]
			| sort_by(.target_rank, -.group_count, (.focusHistoryID // 999999), .distance)
			| .[0].direction // empty
		' 2>/dev/null
	)"; then
		return 1
	fi

	if [[ "$direction" =~ ^[lrud]$ ]]; then
		printf '%s\n' "$direction"
		return 0
	fi

	return 1
}

ensure_active_window_normal() {
	run_dispatch 'hl.dsp.window.fullscreen({ action = "unset" })'
	run_dispatch 'hl.dsp.window.float({ action = "off" })'
}

move_into_container() {
	local direction="$1"

	run_dispatch "hl.dsp.window.move({ into_or_create_group = \"${direction}\" })"
}

move_window_to_workspace() {
	local workspace="$1"
	local address="$2"

	run_dispatch "hl.dsp.window.move({ workspace = ${workspace}, window = \"address:${address}\" })"
}

bring_container_to_active_workspace() {
	local container_address
	local target_workspace
	local container_addresses=()
	local address
	local address_workspace

	container_address="$(container_anchor_address)" || return 1
	target_workspace="$(active_workspace_id)" || return 1

	[[ "$container_address" =~ ^0x[0-9a-fA-F]+$ ]] || return 1
	[[ "$target_workspace" =~ ^-?[0-9]+$ ]] || return 1

	mapfile -t container_addresses < <(container_window_addresses "$container_address")

	if (( ${#container_addresses[@]} == 0 )); then
		return 1
	fi

	for address in "${container_addresses[@]}"; do
		address_workspace="$(client_workspace_id "$address" || true)"

		if [[ "$address_workspace" == "$target_workspace" ]]; then
			continue
		fi

		move_window_to_workspace "$target_workspace" "$address" || return 1
	done
}

lock_active_container() {
	run_dispatch 'hl.dsp.group.lock_active({ action = "lock" })'
}

create_container_from_active_window() {
	run_dispatch 'hl.dsp.group.toggle({})'
	lock_active_container
}

add_to_group() {
	local direction
	local state=0

	if command -v jq >/dev/null 2>&1; then
		forget_stale_container_anchor
	fi

	if active_window_in_container; then
		return 0
	else
		state=$?
	fi

	if [[ "$state" -eq 1 ]]; then
		if active_window_in_native_group; then
			notify "Active window is already in another native group."
			return 1
		fi

		ensure_active_window_normal || return 1
		bring_container_to_active_workspace || true

		if direction="$(container_direction_on_active_workspace)"; then
			move_into_container "$direction" || return 1

			if active_window_in_container; then
				remember_container_anchor || true
				lock_active_container
				return 0
			fi
		fi

		create_container_from_active_window
		remember_container_anchor || true
		return
	fi

	notify "Could not inspect the active window."
	return 1
}

move_container_here() {
	local container_address
	local target_workspace

	if ! command -v jq >/dev/null 2>&1; then
		notify "Could not inspect the Container."
		return 1
	fi

	target_workspace="$(active_workspace_id || true)"
	forget_stale_container_anchor
	container_address="$(container_anchor_address || true)"

	if [[ ! "$target_workspace" =~ ^-?[0-9]+$ ]]; then
		notify "Could not inspect the active workspace."
		return 1
	fi

	if [[ ! "$container_address" =~ ^0x[0-9a-fA-F]+$ ]]; then
		notify "No Container to move."
		return 1
	fi

	bring_container_to_active_workspace || {
		notify "Could not move the Container."
		return 1
	}
}

focus_visible_container_for_cycle() {
	local state
	local address

	if ! command -v jq >/dev/null 2>&1; then
		return 1
	fi

	forget_stale_container_anchor

	if active_window_in_container; then
		return 0
	else
		state=$?
	fi

	if [[ "$state" -ne 1 ]]; then
		return 0
	fi

	address="$(remembered_container_active_address || true)"

	if [[ "$address" =~ ^0x[0-9a-fA-F]+$ ]]; then
		run_dispatch "hl.dsp.focus({ window = \"address:${address}\" })" || return 1
		return 0
	fi

	return 1
}

cycle_window() {
	local direction="$1"

	focus_visible_container_for_cycle || return 0
	run_dispatch "hl.dsp.group.${direction}({})"
}

next_window() {
	cycle_window next
}

prev_window() {
	cycle_window prev
}

close_target_address() {
	if active_window_in_container; then
		active_window_address
		return
	fi

	remembered_container_active_address
}

group_contains_address() {
	local reference_address="$1"
	local target_address="$2"
	local group_addresses=()
	local group_address

	mapfile -t group_addresses < <(group_addresses_for_window "$reference_address")

	if (( ${#group_addresses[@]} == 0 )); then
		[[ "$reference_address" == "$target_address" ]]
		return
	fi

	for group_address in "${group_addresses[@]}"; do
		if [[ "$group_address" == "$target_address" ]]; then
			return 0
		fi
	done

	return 1
}

container_has_window() {
	local address="$1"
	local anchor_address

	anchor_address="$(container_anchor_address || true)"

	if [[ "$anchor_address" =~ ^0x[0-9a-fA-F]+$ ]] && group_contains_address "$anchor_address" "$address"; then
		return 0
	fi

	return 1
}

repair_container_anchor_before_close() {
	local address="$1"
	local target_address
	local grouped_count
	local remaining_address
	local anchor_address

	if ! read -r target_address grouped_count remaining_address < <(window_close_state "$address"); then
		return 1
	fi

	if [[ "$target_address" != "$address" || ! "$grouped_count" =~ ^[0-9]+$ ]]; then
		return 1
	fi

	anchor_address="$(stored_container_anchor_address || true)"

	if (( grouped_count > 0 )); then
		if [[ "$remaining_address" =~ ^0x[0-9a-fA-F]+$ ]]; then
			if [[ -z "$anchor_address" || "$anchor_address" == "$address" ]]; then
				remember_container_anchor "$remaining_address" || true
			fi
		elif [[ -z "$anchor_address" || "$anchor_address" == "$address" ]]; then
			forget_container_anchor || true
		fi

		return 0
	fi

	if [[ "$anchor_address" == "$address" ]]; then
		forget_container_anchor || true
	fi
}

focus_window_if_needed() {
	local address="$1"
	local active_address

	active_address="$(active_window_address || true)"

	if [[ "$active_address" == "$address" ]]; then
		return 0
	fi

	run_dispatch "hl.dsp.focus({ window = \"address:${address}\" })"
}

select_window() {
	local address="${1:-}"
	local original_address
	local restore_original=false

	if [[ ! "$address" =~ ^0x[0-9a-fA-F]+$ ]]; then
		notify "Invalid window address."
		return 1
	fi

	if ! command -v jq >/dev/null 2>&1; then
		notify "Could not inspect the Container."
		return 1
	fi

	forget_stale_container_anchor

	if ! client_exists "$address"; then
		notify "Window is not available."
		return 1
	fi

	if ! container_has_window "$address"; then
		notify "Window is not in the Container."
		return 1
	fi

	original_address="$(active_window_address || true)"

	if [[ "$original_address" =~ ^0x[0-9a-fA-F]+$ && "$original_address" != "$address" ]]; then
		if ! group_contains_address "$address" "$original_address"; then
			restore_original=true
		fi
	fi

	run_dispatch "hl.dsp.focus({ window = \"address:${address}\" })" || return 1

	if [[ "$restore_original" == true ]] && client_exists "$original_address"; then
		run_dispatch "hl.dsp.focus({ window = \"address:${original_address}\" })" || true
	fi
}

close_window() {
	local address="${1:-}"

	if ! command -v jq >/dev/null 2>&1; then
		notify "Could not inspect the Container."
		return 1
	fi

	forget_stale_container_anchor

	if [[ -z "$address" ]]; then
		address="$(close_target_address || true)"
	fi

	if [[ ! "$address" =~ ^0x[0-9a-fA-F]+$ ]]; then
		notify "No Container window to close."
		return 1
	fi

	if ! client_exists "$address"; then
		notify "Window is not available."
		return 1
	fi

	if ! container_has_window "$address"; then
		notify "Window is not in the Container."
		return 1
	fi

	focus_window_if_needed "$address" || return 1
	repair_container_anchor_before_close "$address" || true
	run_dispatch 'hl.dsp.window.close({})'
}

remove_window() {
	local address="${1:-}"
	local active_address
	local grouped_count
	local remaining_address
	local container_address
	local state=0

	if ! command -v jq >/dev/null 2>&1; then
		notify "Could not inspect the active window."
		return 1
	fi

	forget_stale_container_anchor

	if [[ -n "$address" ]]; then
		remove_window_by_address "$address"
		return
	fi

	if active_window_in_container; then
		:
	else
		state=$?

		if [[ "$state" -eq 2 ]]; then
			notify "Could not inspect the active window."
			return 1
		fi

		return 0
	fi

	if ! read -r active_address grouped_count remaining_address < <(active_window_remove_state); then
		notify "Could not inspect the active window."
		return 1
	fi

	if [[ -z "$active_address" || ! "$grouped_count" =~ ^[0-9]+$ ]]; then
		notify "Could not inspect the active window."
		return 1
	fi

	if (( grouped_count > 0 )); then
		run_dispatch 'hl.dsp.window.move({ out_of_group = true })' || return 1

		if [[ "$remaining_address" =~ ^0x[0-9a-fA-F]+$ ]]; then
			remember_container_anchor "$remaining_address" || true
		else
			forget_container_anchor || true
		fi

		return 0
	fi

	container_address="$(container_anchor_address || true)"

	if [[ -n "$container_address" && "$active_address" == "$container_address" ]]; then
		forget_container_anchor || true
	fi

	return 0
}

remove_window_by_address() {
	local address="$1"
	local target_address
	local grouped_count
	local remaining_address
	local anchor_address

	if [[ ! "$address" =~ ^0x[0-9a-fA-F]+$ ]]; then
		notify "Invalid window address."
		return 1
	fi

	if ! client_exists "$address"; then
		notify "Window is not available."
		return 1
	fi

	if ! container_has_window "$address"; then
		notify "Window is not in the Container."
		return 1
	fi

	if ! read -r target_address grouped_count remaining_address < <(window_close_state "$address"); then
		notify "Could not inspect the Container."
		return 1
	fi

	if [[ "$target_address" != "$address" || ! "$grouped_count" =~ ^[0-9]+$ ]]; then
		notify "Could not inspect the Container."
		return 1
	fi

	if (( grouped_count > 0 )); then
		focus_window_if_needed "$address" || return 1
		run_dispatch 'hl.dsp.window.move({ out_of_group = true })' || return 1

		anchor_address="$(stored_container_anchor_address || true)"

		if [[ "$remaining_address" =~ ^0x[0-9a-fA-F]+$ ]]; then
			if [[ -z "$anchor_address" || "$anchor_address" == "$address" ]]; then
				remember_container_anchor "$remaining_address" || true
			fi
		elif [[ -z "$anchor_address" || "$anchor_address" == "$address" ]]; then
			forget_container_anchor || true
		fi

		return 0
	fi

	anchor_address="$(stored_container_anchor_address || true)"

	if [[ "$anchor_address" == "$address" ]]; then
		forget_container_anchor || true
	fi
}

move_group_window() {
	local address="$1"
	local forward="$2"

	run_dispatch "hl.dsp.group.move_window({ forward = ${forward}, window = \"address:${address}\" })"
}

reorder_window() {
	local address="${1:-}"
	local target_index="${2:-}"
	local group_addresses=()
	local source_index=-1
	local group_count
	local steps
	local i

	if [[ ! "$address" =~ ^0x[0-9a-fA-F]+$ ]]; then
		notify "Invalid window address."
		return 1
	fi

	if [[ ! "$target_index" =~ ^[0-9]+$ ]]; then
		notify "Invalid Container index."
		return 1
	fi

	if ! command -v jq >/dev/null 2>&1; then
		notify "Could not inspect the Container."
		return 1
	fi

	forget_stale_container_anchor

	if ! container_has_window "$address"; then
		notify "Window is not in the Container."
		return 1
	fi

	mapfile -t group_addresses < <(group_addresses_for_window "$address")
	group_count="${#group_addresses[@]}"

	if (( group_count < 2 )); then
		return 0
	fi

	for i in "${!group_addresses[@]}"; do
		if [[ "${group_addresses[$i]}" == "$address" ]]; then
			source_index="$i"
			break
		fi
	done

	if (( source_index < 0 )); then
		notify "Window is not in a Container."
		return 1
	fi

	if (( target_index >= group_count )); then
		target_index=$((group_count - 1))
	fi

	if (( source_index == target_index )); then
		return 0
	fi

	if (( source_index < target_index )); then
		steps=$((target_index - source_index))

		for ((i = 0; i < steps; i++)); do
			move_group_window "$address" true || return 1
		done
	else
		steps=$((source_index - target_index))

		for ((i = 0; i < steps; i++)); do
			move_group_window "$address" false || return 1
		done
	fi
}

jump_window() {
	local address="${1:-}"

	if [[ ! "$address" =~ ^0x[0-9a-fA-F]+$ ]]; then
		notify "Invalid window address."
		return 1
	fi

	if ! command -v jq >/dev/null 2>&1; then
		notify "Could not inspect the Container."
		return 1
	fi

	forget_stale_container_anchor

	if ! container_has_window "$address"; then
		notify "Window is not in the Container."
		return 1
	fi

	run_dispatch "hl.dsp.focus({ window = \"address:${address}\" })"
}

wofi_menu() {
	local choice

	if ! command -v wofi >/dev/null 2>&1; then
		notify "wofi is required for the menu."
		return 1
	fi

	choice="$(
		printf '%s\n' \
			"Add to Container" \
			"Move Container Here" \
			"Remove from Container" \
			"Close Window Inside Container" \
			"Prev" \
			"Next" |
			wofi --dmenu --prompt "$app_name"
	)" || return 0

	case "$choice" in
		"Add to Container") add_to_group ;;
		"Move Container Here") move_container_here ;;
		"Remove from Container") remove_window ;;
		"Close Window Inside Container") close_window ;;
		"Prev") prev_window ;;
		"Next") next_window ;;
		"") return 0 ;;
		*) notify "Unknown menu action: $choice"; return 1 ;;
	esac
}

qs_dir() {
	local script_dir

	script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
	printf '%s\n' "${script_dir}/../qs"
}

js_string() {
	local value="$1"

	value="${value//\\/\\\\}"
	value="${value//\"/\\\"}"
	printf '%s' "$value"
}

write_qs_runtime_config() {
	local runtime_file
	local tmp
	local command_path

	runtime_file="$(qs_dir)/HyprGroupRuntime.js"
	tmp="${runtime_file}.$$"
	command_path="$(js_string "$(command_path)")"

	{
		printf '%s\n' ".pragma library"
		printf 'var commandPath = "%s";\n' "$command_path"
	} >"$tmp"
	mv "$tmp" "$runtime_file"
}

qs_running() {
	quickshell list --path "$(qs_dir)" --any-display 2>/dev/null | grep -q '^Instance '
}

cursor_position() {
	local pos
	local x
	local y

	if ! pos="$(hyprctl cursorpos 2>/dev/null)"; then
		return 1
	fi

	pos="${pos// /}"
	x="${pos%%,*}"
	y="${pos#*,}"

	if [[ "$x" =~ ^-?[0-9]+$ && "$y" =~ ^-?[0-9]+$ ]]; then
		printf '%s %s\n' "$x" "$y"
		return 0
	fi

	return 1
}

daemon() {
	if ! command -v quickshell >/dev/null 2>&1; then
		return 1
	fi

	write_qs_runtime_config || return 1

	if qs_running; then
		return 0
	fi

	quickshell --path "$(qs_dir)" --daemonize >/dev/null 2>&1
}

menu() {
	local dir
	local coords
	local x
	local y

	dir="$(qs_dir)"

	if command -v quickshell >/dev/null 2>&1; then
		daemon || return 1
		if coords="$(cursor_position)"; then
			x="${coords% *}"
			y="${coords#* }"
			quickshell ipc --path "$dir" --any-display call hyprgroup toggleAt "$x" "$y"
		else
			quickshell ipc --path "$dir" --any-display call hyprgroup toggle
		fi
		return 0
	fi

	wofi_menu
}

main() {
	local action="${1:-menu}"

	case "$action" in
		menu) menu ;;
		daemon) daemon ;;
		add) add_to_group ;;
		move-here) move_container_here ;;
		close) close_window "${2:-}" ;;
		select) select_window "${2:-}" ;;
		reorder) reorder_window "${2:-}" "${3:-}" ;;
		snapshot) container_snapshot ;;
		jump) jump_window "${2:-}" ;;
		next) next_window ;;
		prev) prev_window ;;
		remove) remove_window "${2:-}" ;;
		-h|--help|help) usage ;;
		*) usage >&2; return 2 ;;
	esac
}

main "$@"
